# Database Configuration
# Copy this file to .env and update the values
# For local development with PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/oyana_db?schema=public"

# Example with Supabase:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Environment
NODE_ENV="development"

# API Configuration
PORT=3000

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Supabase Configuration (if using Supabase)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Paystack Configuration
PAYSTACK_SECRET_KEY="sk_test_your_secret_key"
PAYSTACK_PUBLIC_KEY="pk_test_your_public_key"
PAYSTACK_WALLET_CALLBACK_URL="https://your-app.example.com/wallet/funding/callback"
PAYSTACK_REQUEST_TIMEOUT_MS=15000

# Prembly Checker Widget (NIN/KYC)
PREMBLY_WIDGET_ID="your-widget-id"
PREMBLY_WIDGET_KEY="your-widget-key"
PREMBLY_WIDGET_BASE_URL="https://backend.prembly.com"
PREMBLY_WIDGET_INITIATE_ENDPOINT="/api/v1/checker-widget/sdk/sessions/initiate/"
PREMBLY_WIDGET_PUBLIC_URL="https://dv7wajvnnyl16.cloudfront.net/"
PREMBLY_REQUEST_TIMEOUT_MS=15000

# JWT/Auth
JWT_SECRET="your-jwt-secret-change-this-in-production"
JWT_EXPIRATION="7d"

# Storage
STORAGE_BUCKET_NAME="oyana-storage"

# Google Maps API (for address autocomplete and geocoding)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Business Configuration
# Default commission rate in basis points (100 bps = 1%)
# Example: 1000 = 10%, 250 = 2.5%
DEFAULT_SHIPMENT_COMMISSION_RATE_BPS=1000

# Allowed shipment currencies (comma-separated)
ALLOWED_SHIPMENT_CURRENCIES="NGN"
