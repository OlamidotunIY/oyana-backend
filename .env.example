# Database Configuration (PostgreSQL)
# Copy this file to .env and update the values
# Connection pool URL for app runtime
DATABASE_URL="postgresql://oyana:oyana_dev_password@localhost:5432/oyana"
# Direct URL for Prisma migrations
DIRECT_URL="postgresql://oyana:oyana_dev_password@localhost:5432/oyana"

# PostgreSQL credentials (used by docker-compose)
POSTGRES_DB=oyana
POSTGRES_USER=oyana
POSTGRES_PASSWORD=oyana_dev_password

# Environment
NODE_ENV="development"

# API Configuration
PORT=3000

# Redis (BullMQ + subscriptions)
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=""
REDIS_PASSWORD=""
REDIS_TLS=false

# Dispatch worker scheduling
DISPATCH_RECONCILE_INTERVAL_SECONDS=120
DISPATCH_WORKER_BATCH_SIZE=100
# Retry settings for periodic dispatch reconcile DB operations
DISPATCH_RECONCILE_DB_MAX_RETRIES=4
DISPATCH_RECONCILE_DB_BASE_DELAY_MS=500

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Google OAuth (for social sign-in from mobile)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# SMTP / Email (for OTP and password reset emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Oyana <noreply@oyana.com>"

# SMS / Phone OTP
# Supported providers: console, twilio
SMS_PROVIDER="console"
SMS_TWILIO_ACCOUNT_SID=""
SMS_TWILIO_AUTH_TOKEN=""
# Prefer a Messaging Service SID if you have one
SMS_TWILIO_MESSAGING_SERVICE_SID=""
# Or use a direct Twilio phone number
SMS_TWILIO_FROM_NUMBER=""

# Expo push delivery
# Optional access token if Expo push security is enabled
EXPO_ACCESS_TOKEN=""

# Paystack Configuration
PAYSTACK_SECRET_KEY="sk_test_your_secret_key"
PAYSTACK_PUBLIC_KEY="pk_test_your_public_key"
PAYSTACK_WALLET_CALLBACK_URL="https://your-app.example.com/wallet/funding/callback"
PAYSTACK_REQUEST_TIMEOUT_MS=15000

# Prembly KYC
PREMBLY_BASE_URL="https://backend.prembly.com"
PREMBLY_APP_ID="your-app-id"
PREMBLY_API_KEY="your-api-key"
PREMBLY_NIN_FACE_ENDPOINT="/api/v1/biometrics/merchant/data/verification/nin_face"
PREMBLY_PHONE_ENDPOINT="/api/v1/biometrics/merchant/data/verification/basic_phone_number_1"
PREMBLY_PLATE_ENDPOINT="/api/v1/biometrics/merchant/data/verification/plate_number"
# Optional VIN check endpoint (leave blank to disable VIN verification)
PREMBLY_VIN_ENDPOINT=""
# Optional polling endpoint (leave blank to disable syncKycStatus polling)
PREMBLY_STATUS_ENDPOINT=""
PREMBLY_REQUEST_TIMEOUT_MS=15000

# Prembly webhook security
PREMBLY_WEBHOOK_SECRET=""
# Optional comma-separated source IP allowlist for webhook endpoint
PREMBLY_WEBHOOK_IP_ALLOWLIST=""

# KYC storage
PREMBLY_KYC_BUCKET="kyc-verifications"
PREMBLY_KYC_UPLOAD_URL_TTL_SECONDS=900
PREMBLY_KYC_ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp"
PREMBLY_KYC_MAX_FILE_SIZE_BYTES=5242880

# Google Cloud Storage credentials
# Leave these blank when using Application Default Credentials.
GOOGLE_CLOUD_PROJECT_ID=""
GOOGLE_CLOUD_KEY_FILENAME=""
GOOGLE_CLOUD_CLIENT_EMAIL=""
GOOGLE_CLOUD_PRIVATE_KEY=""

# Raw payload retention
PREMBLY_RAW_PAYLOAD_RETENTION_DAYS=180
PREMBLY_RAW_PAYLOAD_CLEANUP_ENABLED=true
PREMBLY_RAW_PAYLOAD_CLEANUP_INTERVAL_MINUTES=360

# JWT/Auth
JWT_SECRET="your-jwt-secret-change-this-in-production"
JWT_EXPIRATION="15m"

# Storage
STORAGE_BUCKET_NAME="oyana-storage"

# Google Maps API (for address autocomplete and geocoding)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Business Configuration
# Default commission rate in basis points (100 bps = 1%)
# Example: 1000 = 10%, 250 = 2.5%
DEFAULT_SHIPMENT_COMMISSION_RATE_BPS=1000

# Allowed shipment currencies (comma-separated)
ALLOWED_SHIPMENT_CURRENCIES="NGN"
