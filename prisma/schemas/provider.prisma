// ============================================================================
// PROVIDER DOMAIN: Providers, Members, Vehicles, Prembly-managed KYC
// ============================================================================

model Provider {
  id                      String           @id @default(uuid()) @db.Uuid
  businessName            String           @map("business_name")
  driverType              VehicleCategory? @map("driver_type")
  profileId               String?          @unique @map("contact_profile_id") @db.Uuid
  status                  String           @default("pending")
  isAvailable             Boolean          @default(false) @map("is_available")
  availabilityUpdatedAt   DateTime?        @map("availability_updated_at") @db.Timestamptz(6)
  minWalletThresholdMinor BigInt           @default(0) @map("min_wallet_threshold_minor")
  ratingAvg               Decimal          @default(0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount             Int              @default(0) @map("rating_count")
  priorityScore           Int              @default(0) @map("priority_score")
  createdAt               DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  contactProfile      Profile?             @relation("ProviderContact", fields: [profileId], references: [id])
  driverProfile       DriverProfile?
  members             ProviderMember[]
  kycProfile          ProviderKycProfile?
  kycChecks           ProviderKycCheck[]
  kycMedia            ProviderKycMedia[]
  dispatchOffers      DispatchOffer[]
  shipmentAssignments ShipmentAssignment[]
  shipmentBids        ShipmentBid[]
  ratings             Rating[]
  penalties           ProviderPenalty[]
  slaRules            SlaRule[]

  @@index([status])
  @@index([priorityScore(sort: Desc), ratingAvg(sort: Desc)])
  @@map("providers")
}

model ProviderMember {
  providerId String   @map("provider_id") @db.Uuid
  profileId  String   @map("profile_id") @db.Uuid
  role       String
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([providerId, profileId])
  @@map("provider_members")
}

model ProviderKycProfile {
  id                    String    @id @default(uuid()) @db.Uuid
  providerId            String    @unique @map("provider_id") @db.Uuid
  overallStatus         String    @default("pending") @map("overall_status")
  kycLevel              Int       @default(0) @map("kyc_level")
  ninStatus             String    @default("unverified") @map("nin_status")
  phoneStatus           String    @default("unverified") @map("phone_status")
  faceStatus            String    @default("unverified") @map("face_status")
  ninVerifiedAt         DateTime? @map("nin_verified_at") @db.Timestamptz(6)
  phoneVerifiedAt       DateTime? @map("phone_verified_at") @db.Timestamptz(6)
  faceVerifiedAt        DateTime? @map("face_verified_at") @db.Timestamptz(6)
  faceConfidence        Decimal?  @map("face_confidence") @db.Decimal(7, 4)
  maskedNin             String?   @map("masked_nin")
  maskedPhone           String?   @map("masked_phone")
  failureSummary        String?   @map("failure_summary")
  lastVendorSyncAt      DateTime? @map("last_vendor_sync_at") @db.Timestamptz(6)
  lastCheckAt           DateTime? @map("last_check_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  provider Provider           @relation(fields: [providerId], references: [id], onDelete: Cascade)
  checks   ProviderKycCheck[]

  @@index([overallStatus])
  @@index([kycLevel])
  @@map("provider_kyc_profiles")
}

model ProviderKycCheck {
  id                  String    @id @default(uuid()) @db.Uuid
  providerId          String    @map("provider_id") @db.Uuid
  profileId           String?   @map("profile_id") @db.Uuid
  checkType           String    @map("check_type")
  status              String    @default("pending")
  vendor              String    @default("prembly")
  vendorReference     String?   @map("vendor_reference")
  responseCode        String?   @map("response_code")
  confidence          Decimal?  @db.Decimal(7, 4)
  message             String?
  maskedIdentifier    String?   @map("masked_identifier")
  normalizedData      Json?     @map("normalized_data")
  rawRequest          Json?     @map("raw_request")
  rawResponse         Json?     @map("raw_response")
  expiresAt           DateTime? @map("expires_at") @db.Timestamptz(6)
  verifiedAt          DateTime? @map("verified_at") @db.Timestamptz(6)
  failedAt            DateTime? @map("failed_at") @db.Timestamptz(6)
  initiatedByProfileId String?  @map("initiated_by_profile_id") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  provider   Provider            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  profile    ProviderKycProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  initiatedBy Profile?           @relation("ProviderKycCheckInitiator", fields: [initiatedByProfileId], references: [id], onDelete: SetNull)
  media      ProviderKycMedia[]  @relation("KycCheckMedia")

  @@unique([vendorReference], name: "unique_provider_kyc_check_vendor_reference")
  @@index([providerId, checkType, createdAt(sort: Desc)])
  @@index([status])
  @@index([profileId])
  @@map("provider_kyc_checks")
}

model ProviderKycMedia {
  id                String   @id @default(uuid()) @db.Uuid
  providerId        String   @map("provider_id") @db.Uuid
  checkId           String?  @map("check_id") @db.Uuid
  storageBucket     String   @map("storage_bucket")
  storagePath       String   @map("storage_path")
  mimeType          String?  @map("mime_type")
  sizeBytes         BigInt?  @map("size_bytes")
  uploadState       String   @default("uploaded") @map("upload_state")
  uploadedByProfileId String? @map("uploaded_by_profile_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  provider   Provider          @relation(fields: [providerId], references: [id], onDelete: Cascade)
  check      ProviderKycCheck? @relation("KycCheckMedia", fields: [checkId], references: [id], onDelete: SetNull)
  uploadedBy Profile?          @relation("ProviderKycMediaUploader", fields: [uploadedByProfileId], references: [id], onDelete: SetNull)

  @@unique([storageBucket, storagePath])
  @@index([providerId, createdAt(sort: Desc)])
  @@index([checkId])
  @@map("provider_kyc_media")
}
