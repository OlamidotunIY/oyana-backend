model Profile {
  id                String        @id @db.Uuid
  email             String        @unique
  passwordHash      String?       @map("password_hash")
  roles             UserType[]    @default([individual]) @map("user_roles")
  firstName         String?       @map("first_name")
  lastName          String?       @map("last_name")
  phoneE164         String?       @unique @map("phone_e164")
  phoneVerified     Boolean       @default(false) @map("phone_verified")
  phoneVerifiedAt   DateTime?     @map("phone_verified_at") @db.Timestamptz(6)
  state             State
  referralCode      String?       @map("referral_code")
  preferredLanguage String        @default("en") @map("preferred_language")
  status            ProfileStatus @default(active)
  lastLoginAt       DateTime?     @map("last_login_at") @db.Timestamptz(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  sessions                  UserSession[]
  socialAccounts            SocialAccount[]
  customerShipments         Shipment[]                 @relation("CustomerShipments")
  providerMembers           ProviderMember[]
  contactForProviders       Provider[]                 @relation("ProviderContact")
  adminSessions             AdminSession[]
  shipmentEventActors       ShipmentEvent[]
  cancelledShipments        Shipment[]                 @relation("ShipmentCanceller")
  walletAccounts            WalletAccount[]            @relation("ProfileWallet")
  ratingsMade               Rating[]
  shipmentBidAwards         ShipmentBidAward[]
  initiatedKycChecks        ProviderKycCheck[]         @relation("ProviderKycCheckInitiator")
  uploadedKycMedia          ProviderKycMedia[]         @relation("ProviderKycMediaUploader")
  podUploads                PodUpload[]
  shipmentAssignmentsDriver ShipmentAssignment[]
  refundsInitiated          Refund[]                   @relation("RefundInitiator")
  refundsApproved           Refund[]                   @relation("RefundApprover")
  waybillReviews            Waybill[]
  userAddresses             UserAddress[]
  phoneVerificationAttempts PhoneVerificationAttempt[]
  walletCardMethods         WalletCardMethod[]
  savedBankAccounts         WalletSavedBankAccount[]
  walletWithdrawals         WalletWithdrawal[]
  walletIdempotencyKeys     WalletIdempotencyKey[]
  supportTickets            SupportTicket[]            @relation("SupportTicketOwner")
  assignedSupportTickets    SupportTicket[]            @relation("SupportTicketAssignee")
  supportTicketMessages     SupportTicketMessage[]     @relation("SupportTicketMessageAuthor")
  disputeCases              DisputeCase[]              @relation("DisputeOwner")
  resolvedDisputes          DisputeCase[]              @relation("DisputeResolver")
  disputeEvents             DisputeEvent[]             @relation("DisputeEventActor")
  invoices                  Invoice[]                  @relation("ProfileInvoices")
  fraudFlagsRaised          FraudFlag[]                @relation("FraudRaisedBy")
  fraudFlagsAssigned        FraudFlag[]                @relation("FraudAssignedTo")
  fraudFlagsResolved        FraudFlag[]                @relation("FraudResolvedBy")
  platformConfigUpdates     PlatformConfig[]           @relation("PlatformConfigUpdater")
  notifications             Notification[]             @relation("ProfileNotifications")

  @@map("profiles")
}

enum ProfileStatus {
  active
  suspended
  deleted
}

enum UserType {
  individual
  business
  admin
}

model UserAddress {
  id          String   @id @db.Uuid
  profileId   String   @db.Uuid
  address     String
  city        String
  state       State
  postalCode  String
  label       String?
  countryCode String   @default("NG") @map("country_code") @db.Char(2)
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  profile          Profile    @relation(fields: [profileId], references: [id])
  pickupShipments  Shipment[] @relation("PickupAddress")
  dropoffShipments Shipment[] @relation("DropoffAddress")

  @@index([profileId, createdAt(sort: Desc)])
  @@map("user_addresses")
}
