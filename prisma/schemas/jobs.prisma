// ============================================================================
// JOBS DOMAIN: Jobs, Locations, Job Items, Job Events
// ============================================================================

model Location {
    id           String   @id @default(uuid()) @db.Uuid
    label        String?
    addressLine1 String   @map("address_line1")
    addressLine2 String?  @map("address_line2")
    city         String?
    state        String?
    countryCode  String   @default("NG") @map("country_code") @db.Char(2)
    lat          Float?
    lng          Float?
    createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

    // Relations
    pickupJobs  Job[] @relation("PickupLocation")
    dropoffJobs Job[] @relation("DropoffLocation")

    @@index([lat, lng])
    @@map("locations")
}

model Job {
    id                    String    @id @default(uuid()) @db.Uuid
    publicCode            String    @unique @map("public_code")
    customerProfileId     String    @map("customer_profile_id") @db.Uuid
    mode                  String
    vehicleCategory       String    @map("vehicle_category")
    status                String
    pickupLocationId      String    @map("pickup_location_id") @db.Uuid
    dropoffLocationId     String    @map("dropoff_location_id") @db.Uuid
    scheduledAt           DateTime? @map("scheduled_at") @db.Timestamptz(6)
    packageDescription    String?   @map("package_description")
    packageValueMinor     BigInt?   @default(0) @map("package_value_minor")
    specialInstructions   String?   @map("special_instructions")
    pricingCurrency       String    @default("NGN") @map("pricing_currency") @db.Char(3)
    quotedPriceMinor      BigInt?   @map("quoted_price_minor")
    finalPriceMinor       BigInt?   @map("final_price_minor")
    commissionRateBps     Int       @default(0) @map("commission_rate_bps")
    commissionAmountMinor BigInt    @default(0) @map("commission_amount_minor")
    createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
    cancelledAt           DateTime? @map("cancelled_at") @db.Timestamptz(6)
    cancelledByProfileId  String?   @map("cancelled_by_profile_id") @db.Uuid
    cancellationReason    String?   @map("cancellation_reason")

    // Relations
    customer           Profile             @relation("CustomerJobs", fields: [customerProfileId], references: [id])
    pickupLocation     Location            @relation("PickupLocation", fields: [pickupLocationId], references: [id])
    dropoffLocation    Location            @relation("DropoffLocation", fields: [dropoffLocationId], references: [id])
    cancelledBy        Profile?            @relation("JobCanceller", fields: [cancelledByProfileId], references: [id])
    items              JobItem[]
    events             JobEvent[]
    dispatchBatch      DispatchBatch?
    assignment         JobAssignment?
    bids               JobBid[]
    bidAward           BidAward?
    financials         JobFinancials?
    milestones         JobMilestone[]
    otpChallenge       OtpChallenge?
    podUploads         PodUpload[]
    waybills           Waybill[]
    rating             Rating?
    penalties          ProviderPenalty[]
    walletTransactions WalletTransaction[]
    refunds            Refund[]

    @@index([customerProfileId, createdAt(sort: Desc)])
    @@index([status, vehicleCategory, mode])
    @@map("jobs")
}

model JobItem {
    id        String   @id @default(uuid()) @db.Uuid
    jobId     String   @map("job_id") @db.Uuid
    name      String
    quantity  Int
    weightKg  Decimal? @map("weight_kg") @db.Decimal(10, 2)
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

    // Relations
    job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

    @@index([jobId])
    @@map("job_items")
}

model JobEvent {
    id             String   @id @default(uuid()) @db.Uuid
    jobId          String   @map("job_id") @db.Uuid
    eventType      String   @map("event_type")
    actorProfileId String?  @map("actor_profile_id") @db.Uuid
    actorRole      String?  @map("actor_role")
    metadata       Json?
    createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

    // Relations
    job   Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
    actor Profile? @relation(fields: [actorProfileId], references: [id])

    @@index([jobId, createdAt])
    @@index([eventType, createdAt])
    @@map("job_events")
}
