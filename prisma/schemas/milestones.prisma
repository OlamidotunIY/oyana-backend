// ============================================================================
// MILESTONES DOMAIN: Shipment Milestones, OTP, POD, Waybills
// ============================================================================

enum ShipmentMilestoneType {
    accepted
    arrived_pickup
    picked_up
    arrived_dropoff
    delivered
    completed
}

enum ShipmentMilestoneStatus {
    pending
    reached
    verified
}

enum OtpPurpose {
    delivery_completion
    handoff_confirmation
    dispute_resolution
}

enum PodUploadType {
    photo
    signature
    document
}

enum WaybillStatus {
    uploaded
    approved
    rejected
}

model ShipmentMilestone {
    id         String                  @id @default(uuid()) @db.Uuid
    shipmentId String                  @map("shipment_id") @db.Uuid
    type       ShipmentMilestoneType
    status     ShipmentMilestoneStatus
    occurredAt DateTime?               @map("occurred_at") @db.Timestamptz(6)
    lat        Float?
    lng        Float?
    metadata   Json?
    createdAt  DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

    // Relations
    shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

    @@unique([shipmentId, type])
    @@index([shipmentId])
    @@map("shipment_milestones")
}

model OtpChallenge {
    id           String     @id @default(uuid()) @db.Uuid
    shipmentId   String     @unique @map("shipment_id") @db.Uuid
    purpose      OtpPurpose @default(delivery_completion)
    otpHash      String     @map("otp_hash")
    expiresAt    DateTime   @map("expires_at") @db.Timestamptz(6)
    verifiedAt   DateTime?  @map("verified_at") @db.Timestamptz(6)
    attemptCount Int        @default(0) @map("attempt_count")
    lockedUntil  DateTime?  @map("locked_until") @db.Timestamptz(6)
    createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

    // Relations
    shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

    @@map("otp_challenges")
}

model PodUpload {
    id            String        @id @default(uuid()) @db.Uuid
    shipmentId    String        @map("shipment_id") @db.Uuid
    type          PodUploadType
    storageBucket String        @map("storage_bucket")
    storagePath   String        @map("storage_path")
    uploadedBy    String?       @map("uploaded_by") @db.Uuid
    createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

    // Relations
    shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
    uploader Profile? @relation(fields: [uploadedBy], references: [id])

    @@index([shipmentId, createdAt(sort: Desc)])
    @@map("pod_uploads")
}

model Waybill {
    id            String        @id @default(uuid()) @db.Uuid
    shipmentId    String        @map("shipment_id") @db.Uuid
    storageBucket String        @map("storage_bucket")
    storagePath   String        @map("storage_path")
    status        WaybillStatus @default(uploaded)
    reviewedBy    String?       @map("reviewed_by") @db.Uuid
    reviewedAt    DateTime?     @map("reviewed_at") @db.Timestamptz(6)
    createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

    // Relations
    shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
    reviewer Profile? @relation(fields: [reviewedBy], references: [id])

    @@index([shipmentId])
    @@map("waybills")
}
