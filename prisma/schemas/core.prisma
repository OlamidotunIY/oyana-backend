// ============================================================================
// CORE DOMAIN: Roles, Permissions, User Profiles, Admin Sessions
// ============================================================================

model Profile {
    id                String        @id @db.Uuid // Same as auth.users.id
    fullName          String?       @map("full_name")
    displayName       String?       @map("display_name")
    phoneE164         String?       @unique @map("phone_e164")
    preferredLanguage String        @default("en") @map("preferred_language")
    status            ProfileStatus @default(active)
    lastLoginAt       DateTime?     @map("last_login_at") @db.Timestamptz(6)
    createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

    // Relations
    userRoles            UserRole[]
    customerJobs         Job[]             @relation("CustomerJobs")
    providerMembers      ProviderMember[]
    contactForProviders  Provider[]        @relation("ProviderContact")
    adminSessions        AdminSession[]
    jobEventActors       JobEvent[]
    cancelledJobs        Job[]             @relation("JobCanceller")
    walletAccounts       WalletAccount[]   @relation("ProfileWallet")
    ratingsMade          Rating[]
    bidAwards            BidAward[]
    kycReviews           ProviderKycCase[] @relation("KycReviewer")
    documentUploads      KycDocument[]
    podUploads           PodUpload[]
    jobAssignmentsDriver JobAssignment[]
    refundsInitiated     Refund[]
    waybillReviews       Waybill[]

    @@map("profiles")
}

model Role {
    id        String   @id @default(uuid()) @db.Uuid
    key       String   @unique
    name      String?
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

    // Relations
    userRoles       UserRole[]
    rolePermissions RolePermission[]

    @@map("roles")
}

model Permission {
    id          String   @id @default(uuid()) @db.Uuid
    key         String   @unique
    description String?
    createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
    updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

    // Relations
    rolePermissions RolePermission[]

    @@map("permissions")
}

model RolePermission {
    roleId       String   @map("role_id") @db.Uuid
    permissionId String   @map("permission_id") @db.Uuid
    createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

    // Relations
    role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
    permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

    @@id([roleId, permissionId])
    @@index([roleId])
    @@index([permissionId])
    @@map("role_permissions")
}

model UserRole {
    profileId String   @map("profile_id") @db.Uuid
    roleId    String   @map("role_id") @db.Uuid
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

    // Relations
    profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
    role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

    @@id([profileId, roleId])
    @@index([profileId])
    @@index([roleId])
    @@map("user_roles")
}

model AdminSession {
    id        String   @id @default(uuid()) @db.Uuid
    profileId String   @map("profile_id") @db.Uuid
    ip        String?  @db.Inet
    userAgent String?  @map("user_agent")
    createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

    // Relations
    profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

    @@index([profileId])
    @@map("admin_sessions")
}

enum ProfileStatus {
    active
    suspended
    deleted
}
