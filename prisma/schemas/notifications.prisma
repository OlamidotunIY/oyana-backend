// ============================================================================
// NOTIFICATIONS DOMAIN: In-app notifications for customer/provider/admin
// ============================================================================

enum NotificationAudience {
  customer
  provider
  admin
}

enum NotificationCategory {
  shipment
  dispatch
  support
  dispute
  system
}

model Notification {
  id                 String               @id @default(uuid()) @db.Uuid
  recipientProfileId String               @map("recipient_profile_id") @db.Uuid
  audience           NotificationAudience
  category           NotificationCategory
  title              String
  body               String
  entityType         String?              @map("entity_type")
  entityId           String?              @map("entity_id")
  metadata           Json?
  isRead             Boolean              @default(false) @map("is_read")
  readAt             DateTime?            @map("read_at") @db.Timestamptz(6)
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  recipientProfile Profile @relation("ProfileNotifications", fields: [recipientProfileId], references: [id], onDelete: Cascade)

  @@index([recipientProfileId, createdAt(sort: Desc)])
  @@index([audience, isRead, createdAt(sort: Desc)])
  @@index([category, createdAt(sort: Desc)])
  @@map("notifications")
}

model PushDevice {
  id                   String   @id @default(uuid()) @db.Uuid
  profileId            String   @map("profile_id") @db.Uuid
  expoPushToken        String   @unique @map("expo_push_token")
  deviceId             String?  @map("device_id")
  platform             String?
  appVersion           String?  @map("app_version")
  pushPermissionStatus String?  @map("push_permission_status")
  isActive             Boolean  @default(true) @map("is_active")
  lastSeenAt           DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, isActive])
  @@index([profileId, lastSeenAt(sort: Desc)])
  @@map("push_devices")
}
